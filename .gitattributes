# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Explicitly mark these as text (always normalize)
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.sh text eol=lf

# Binary files - don't touch
*.db binary
*.sqlite3 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.epub binary
*.whl binary
*.pyc binary
*.pyo binary
*.lance binary
